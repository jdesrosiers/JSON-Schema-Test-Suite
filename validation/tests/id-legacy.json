                    "list": { "$ref": "#/definitions/baz" }
                },
                "definitions": {
                    "baz": {
                        "$id": "baseUriChangeFolder/",
                        "type": "array",
                        "items": { "$ref": "folderInteger.json" }
                    }
                }
            },
            "externalSchemas": {
                "http://localhost:1234/baseUriChangeFolder/folderInteger.json": {
                    "type": "integer"
                }
            },
            "tests": [
                {
                    "description": "number is valid",
                    "data": { "list": [1] },
                    "valid": true
                },
                {
                    "description": "string is invalid",
                    "data": { "list": ["a"] },
                    "valid": false
                }
            ]
        },
