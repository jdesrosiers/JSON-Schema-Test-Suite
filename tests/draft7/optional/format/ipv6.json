                "id": "a52e5370bf9bf423967679b1fb0f6cdc"
            },
            {
                "description": "triple colons is invalid",
                "data": "1:2:3:4:5:::8",
                "valid": false,
                "id": "46cdb9c91cf23d63f5097f41e1ca9380"
            },
            {
                "description": "8 octets",
                "data": "1:2:3:4:5:6:7:8",
                "valid": true,
                "id": "095010e462b00d0f23093f34a98f54b5"
            },
            {
                "description": "insufficient octets without double colons",
