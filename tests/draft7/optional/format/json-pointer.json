[
    {
        "description": "validation of JSON-pointers (JSON String Representation)",
        "schema": { "format": "json-pointer" },
        "tests": [
            {
                "description": "all string formats ignore integers",
                "data": 12,
                "valid": true,
                "id": "7a89783922bc101a2df8209f71c07690"
            },
            {
                "description": "all string formats ignore floats",
                "data": 13.7,
                "valid": true,
                "id": "af254d2a43bb1d1a55ca7834e09d38d7"
            },
            {
                "description": "all string formats ignore objects",
                "data": {},
                "valid": true,
                "id": "d63155bee5351d702c5b9285c7c3e9b1"
            },
            {
                "description": "all string formats ignore arrays",
                "data": [],
                "valid": true,
                "id": "7ed60711213dbf05cd0602888c4a6a78"
            },
            {
                "description": "all string formats ignore booleans",
                "data": false,
                "valid": true,
                "id": "a8b3a8b7e030a01eb7ccee6e4a95f7ce"
            },
            {
                "description": "all string formats ignore nulls",
                "data": null,
                "valid": true,
                "id": "8eab3f7f2c876ed0478f5e158208628f"
            },
            {
                "description": "a valid JSON-pointer",
                "data": "/foo/bar~0/baz~1/%a",
                "valid": true,
                "id": "c8e3464605d5bd2c5b48fbfe39ab829c"
            },
            {
                "description": "not a valid JSON-pointer (~ not escaped)",
                "data": "/foo/bar~",
                "valid": false,
                "id": "12018d8e605bda3fbc00761a9b5ea32b"
            },
            {
                "description": "valid JSON-pointer with empty segment",
                "data": "/foo//bar",
                "valid": true,
                "id": "e28dd6f58c14a3d97956ce4ad9c6a2a1"
            },
            {
                "description": "valid JSON-pointer with the last empty segment",
                "data": "/foo/bar/",
                "valid": true,
                "id": "2e4967ff478de230fb2e1c53c25e652c"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #1",
                "data": "",
                "valid": true,
                "id": "b2fc3ffd7594aeed09a52bb8f94e5498"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #2",
                "data": "/foo",
                "valid": true,
                "id": "b6b7198d423f4f097369f87d5e8a62fb"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #3",
                "data": "/foo/0",
                "valid": true,
                "id": "0c2955eeea4b6964b0389545e95171a9"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #4",
                "data": "/",
                "valid": true,
                "id": "e8f84576bec4495fdf71037101df025f"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #5",
                "data": "/a~1b",
                "valid": true,
                "id": "b9a2a2e908d9a38ce4e1ad558277ef45"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #6",
                "data": "/c%d",
                "valid": true,
                "id": "3f111653ec308a710e6b60407f471f0a"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #7",
                "data": "/e^f",
                "valid": true,
                "id": "fdbb1837a0b712d073d22bd15180322d"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #8",
                "data": "/g|h",
                "valid": true,
                "id": "93dca1f4e343acc91606765335a4fb35"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #9",
                "data": "/i\\j",
                "valid": true,
                "id": "384ea08e283c288f61d7525381b2d3ac"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #10",
                "data": "/k\"l",
                "valid": true,
                "id": "a3beb23194e3470a41707d2580c28e33"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #11",
                "data": "/ ",
                "valid": true,
                "id": "28c414a86b6d2d8dcf6a71a00785bb18"
            },
            {
                "description": "valid JSON-pointer as stated in RFC 6901 #12",
                "data": "/m~0n",
                "valid": true,
                "id": "a4d329207340e10b61b52732c2c1a730"
            },
            {
                "description": "valid JSON-pointer used adding to the last array position",
                "data": "/foo/-",
                "valid": true,
                "id": "f192e0e75e4cac20226ae09573bd721a"
            },
            {
                "description": "valid JSON-pointer (- used as object member name)",
                "data": "/foo/-/bar",
                "valid": true,
                "id": "f65ebb22f4541db541f395261eaace9d"
            },
            {
                "description": "valid JSON-pointer (multiple escaped characters)",
                "data": "/~1~0~0~1~1",
                "valid": true,
                "id": "24d47f208b311783a8dbd7f58c86b5aa"
            },
            {
                "description": "valid JSON-pointer (escaped with fraction part) #1",
                "data": "/~1.1",
                "valid": true,
                "id": "9f7e2fa667f016237341f06c22a1e08a"
            },
            {
                "description": "valid JSON-pointer (escaped with fraction part) #2",
                "data": "/~0.1",
                "valid": true,
                "id": "9bacc332edff097db794ce0065fb1a9c"
            },
            {
                "description": "not a valid JSON-pointer (URI Fragment Identifier) #1",
                "data": "#",
                "valid": false,
                "id": "5e099a81ef108bdf7e77c4237d7b1f64"
            },
            {
                "description": "not a valid JSON-pointer (URI Fragment Identifier) #2",
                "data": "#/",
                "valid": false,
                "id": "6c902c533c239af9623eaa91e7914cbd"
            },
            {
                "description": "not a valid JSON-pointer (URI Fragment Identifier) #3",
                "data": "#a",
                "valid": false,
                "id": "46b51d4cb588108943014e24b3ea54d7"
            },
            {
                "description": "not a valid JSON-pointer (some escaped, but not all) #1",
                "data": "/~0~",
                "valid": false,
                "id": "8acf56d111085312ef380ada624a852f"
            },
            {
                "description": "not a valid JSON-pointer (some escaped, but not all) #2",
                "data": "/~0/~",
                "valid": false,
                "id": "648ee8c94773117a7fd89fb012204bcb"
            },
            {
                "description": "not a valid JSON-pointer (wrong escape character) #1",
                "data": "/~2",
                "valid": false,
                "id": "0587ba11d66d4cb9d17e4dbd232cceaf"
            },
            {
                "description": "not a valid JSON-pointer (wrong escape character) #2",
                "data": "/~-1",
                "valid": false,
                "id": "4a58b7d715507b7d2aeba169d667936d"
            },
            {
                "description": "not a valid JSON-pointer (multiple characters not escaped)",
                "data": "/~~",
                "valid": false,
                "id": "bc7ec6dbc109e87a1770af9e95c1c4a4"
            },
            {
                "description": "not a valid JSON-pointer (isn't empty nor starts with /) #1",
                "data": "a",
                "valid": false,
                "id": "6fb9b9f8d59ffe96b280720c1bacb020"
            },
            {
                "description": "not a valid JSON-pointer (isn't empty nor starts with /) #2",
                "data": "0",
                "valid": false,
                "id": "9f337ad1ec1381348e6e08add9f1eb80"
            },
            {
                "description": "not a valid JSON-pointer (isn't empty nor starts with /) #3",
                "data": "a/a",
                "valid": false,
                "id": "68925ad190ce0d54cdada8df98626089"
            }
        ]
    }
]
