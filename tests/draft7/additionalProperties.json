[
    {
        "description":
            "additionalProperties being false does not allow other properties",
        "schema": {
            "properties": {"foo": {}, "bar": {}},
            "patternProperties": { "^v": {} },
            "additionalProperties": false
        },
        "tests": [
            {
                "description": "no additional properties is valid",
                "data": {"foo": 1},
                "valid": true,
                "id": "0376894b1da7418fd152595e3ffb8467"
            },
            {
                "description": "an additional property is invalid",
                "data": {"foo" : 1, "bar" : 2, "quux" : "boom"},
                "valid": false,
                "id": "5918a0c5ccc3037879c437d35f5d0013"
            },
            {
                "description": "ignores arrays",
                "data": [1, 2, 3],
                "valid": true,
                "id": "72644ff75f11363619bab17d9eea3027"
            },
            {
                "description": "ignores strings",
                "data": "foobarbaz",
                "valid": true,
                "id": "53349756e831f00ff6be03fc66672fa1"
            },
            {
                "description": "ignores other non-objects",
                "data": 12,
                "valid": true,
                "id": "f9910d6b02f1f44b78d910cedb32aeeb"
            },
            {
                "description": "patternProperties are not additional properties",
                "data": {"foo":1, "vroom": 2},
                "valid": true,
                "id": "5bd60384a7cad71873b5e8c1288b377e"
            }
        ]
    },
    {
        "description": "non-ASCII pattern with additionalProperties",
        "schema": {
            "patternProperties": {"^á": {}},
            "additionalProperties": false
        },
        "tests": [
            {
                "description": "matching the pattern is valid",
                "data": {"ármányos": 2},
                "valid": true,
                "id": "323b5115afd078d34b6676b946e711a3"
            },
            {
                "description": "not matching the pattern is invalid",
                "data": {"élmény": 2},
                "valid": false,
                "id": "c949dd66495876ab76830795379bd391"
            }
        ]
    },
    {
        "description": "additionalProperties with schema",
        "schema": {
            "properties": {"foo": {}, "bar": {}},
            "additionalProperties": {"type": "boolean"}
        },
        "tests": [
            {
                "description": "no additional properties is valid",
                "data": {"foo": 1},
                "valid": true,
                "id": "39ae84fe43130a5a6842ce068699b59a"
            },
            {
                "description": "an additional valid property is valid",
                "data": {"foo" : 1, "bar" : 2, "quux" : true},
                "valid": true,
                "id": "f4ae7c8b7562d75be25a049ccd482619"
            },
            {
                "description": "an additional invalid property is invalid",
                "data": {"foo" : 1, "bar" : 2, "quux" : 12},
                "valid": false,
                "id": "870705e29f6b2736963601724c852fef"
            }
        ]
    },
    {
        "description":
            "additionalProperties can exist by itself",
        "schema": {
            "additionalProperties": {"type": "boolean"}
        },
        "tests": [
            {
                "description": "an additional valid property is valid",
                "data": {"foo" : true},
                "valid": true,
                "id": "e378783e827dd7b8da60b4f360297d62"
            },
            {
                "description": "an additional invalid property is invalid",
                "data": {"foo" : 1},
                "valid": false,
                "id": "d56781eb47d259d427b81eb2f1b93b29"
            }
        ]
    },
    {
        "description": "additionalProperties are allowed by default",
        "schema": {"properties": {"foo": {}, "bar": {}}},
        "tests": [
            {
                "description": "additional properties are allowed",
                "data": {"foo": 1, "bar": 2, "quux": true},
                "valid": true,
                "id": "32c07645cf2f4b9e6a06f21947ce664e"
            }
        ]
    },
    {
        "description": "additionalProperties does not look in applicators",
        "schema": {
            "allOf": [
                {"properties": {"foo": {}}}
            ],
            "additionalProperties": {"type": "boolean"}
        },
        "tests": [
            {
                "description": "properties defined in allOf are not examined",
                "data": {"foo": 1, "bar": true},
                "valid": false,
                "id": "c81e14b352656c8931346528f2d06609"
            }
        ]
    },
    {
        "description": "additionalProperties with null valued instance properties",
        "schema": {
            "additionalProperties": {
                "type": "null"
            }
        },
        "tests": [
            {
                "description": "allows null values",
                "data": {"foo": null},
                "valid": true,
                "id": "4bdb184c6285761298bbec20d7a516ff"
            }
        ]
    }
]
