[
    {
        "description": "a schema given for items",
        "schema": {
            "items": {"type": "integer"}
        },
        "tests": [
            {
                "description": "valid items",
                "data": [ 1, 2, 3 ],
                "valid": true,
                "id": "9b996c0fa176f7347a8b5d29ec106943"
            },
            {
                "description": "wrong type of items",
                "data": [1, "x"],
                "valid": false,
                "id": "a3b3bcb3f2c48e93ca7955dfed714972"
            },
            {
                "description": "ignores non-arrays",
                "data": {"foo" : "bar"},
                "valid": true,
                "id": "71ef689dad00ffc16bb6a92a98516346"
            },
            {
                "description": "JavaScript pseudo-array is valid",
                "data": {
                    "0": "invalid",
                    "length": 1
                },
                "valid": true,
                "id": "aca780b4e44d80f5f447a1a6eb5772d4"
            }
        ]
    },
    {
        "description": "an array of schemas for items",
        "schema": {
            "items": [
                {"type": "integer"},
                {"type": "string"}
            ]
        },
        "tests": [
            {
                "description": "correct types",
                "data": [ 1, "foo" ],
                "valid": true,
                "id": "f6a89b1a58fa21fc84aa10b2bcf80095"
            },
            {
                "description": "wrong types",
                "data": [ "foo", 1 ],
                "valid": false,
                "id": "f2217f7ebec645bce337428909839247"
            },
            {
                "description": "incomplete array of items",
                "data": [ 1 ],
                "valid": true,
                "id": "87f31bcb4a1e819ccc94cd36feb90132"
            },
            {
                "description": "array with additional items",
                "data": [ 1, "foo", true ],
                "valid": true,
                "id": "bf55fe83188b22d5c1130b2e8f3a0a88"
            },
            {
                "description": "empty array",
                "data": [ ],
                "valid": true,
                "id": "be8e2f6feb19a25621f2cf7f66793765"
            },
            {
                "description": "JavaScript pseudo-array is valid",
                "data": {
                    "0": "invalid",
                    "1": "valid",
                    "length": 2
                },
                "valid": true,
                "id": "8e075057a220d8d235bc7f7053624544"
            }
        ]
    },
    {
        "description": "items with boolean schema (true)",
        "schema": {"items": true},
        "tests": [
            {
                "description": "any array is valid",
                "data": [ 1, "foo", true ],
                "valid": true,
                "id": "eee597d52779c8f9edf7ecf4a512db56"
            },
            {
                "description": "empty array is valid",
                "data": [],
                "valid": true,
                "id": "308af2f1d8aa19f942c0f8112e217329"
            }
        ]
    },
    {
        "description": "items with boolean schema (false)",
        "schema": {"items": false},
        "tests": [
            {
                "description": "any non-empty array is invalid",
                "data": [ 1, "foo", true ],
                "valid": false,
                "id": "77a62ed77cbf6bc61e13f08a873e67f7"
            },
            {
                "description": "empty array is valid",
                "data": [],
                "valid": true,
                "id": "229e630443cb544d52a2178d9c1c8743"
            }
        ]
    },
    {
        "description": "items with boolean schemas",
        "schema": {
            "items": [true, false]
        },
        "tests": [
            {
                "description": "array with one item is valid",
                "data": [ 1 ],
                "valid": true,
                "id": "042f9f4a2c83db3b6a673e61a78e4e44"
            },
            {
                "description": "array with two items is invalid",
                "data": [ 1, "foo" ],
                "valid": false,
                "id": "b146f48f01919030dc29356e8f97fcc7"
            },
            {
                "description": "empty array is valid",
                "data": [],
                "valid": true,
                "id": "9c14378d4230f1698665ff0999678f4b"
            }
        ]
    },
    {
        "description": "items and subitems",
        "schema": {
            "definitions": {
                "item": {
                    "type": "array",
                    "additionalItems": false,
                    "items": [
                        { "$ref": "#/definitions/sub-item" },
                        { "$ref": "#/definitions/sub-item" }
                    ]
                },
                "sub-item": {
                    "type": "object",
                    "required": ["foo"]
                }
            },
            "type": "array",
            "additionalItems": false,
            "items": [
                { "$ref": "#/definitions/item" },
                { "$ref": "#/definitions/item" },
                { "$ref": "#/definitions/item" }
            ]
        },
        "tests": [
            {
                "description": "valid items",
                "data": [
                    [ {"foo": null}, {"foo": null} ],
                    [ {"foo": null}, {"foo": null} ],
                    [ {"foo": null}, {"foo": null} ]
                ],
                "valid": true,
                "id": "e5ab21eaf00ce60d037a4468f0134512"
            },
            {
                "description": "too many items",
                "data": [
                    [ {"foo": null}, {"foo": null} ],
                    [ {"foo": null}, {"foo": null} ],
                    [ {"foo": null}, {"foo": null} ],
                    [ {"foo": null}, {"foo": null} ]
                ],
                "valid": false,
                "id": "8e1c47a0d456c21e5393285811adc987"
            },
            {
                "description": "too many sub-items",
                "data": [
                    [ {"foo": null}, {"foo": null}, {"foo": null} ],
                    [ {"foo": null}, {"foo": null} ],
                    [ {"foo": null}, {"foo": null} ]
                ],
                "valid": false,
                "id": "16f3fa96444cbbe1cf8591f1c6b29c0c"
            },
            {
                "description": "wrong item",
                "data": [
                    {"foo": null},
                    [ {"foo": null}, {"foo": null} ],
                    [ {"foo": null}, {"foo": null} ]
                ],
                "valid": false,
                "id": "edee315100169bd5644318685b56a486"
            },
            {
                "description": "wrong sub-item",
                "data": [
                    [ {}, {"foo": null} ],
                    [ {"foo": null}, {"foo": null} ],
                    [ {"foo": null}, {"foo": null} ]
                ],
                "valid": false,
                "id": "5a937e4730f4e0fd3d23fc6e440f9742"
            },
            {
                "description": "fewer items is valid",
                "data": [
                    [ {"foo": null} ],
                    [ {"foo": null} ]
                ],
                "valid": true,
                "id": "e89e11892bf58c386b450f48568ca7ab"
            }
        ]
    },
    {
        "description": "nested items",
        "schema": {
            "type": "array",
            "items": {
                "type": "array",
                "items": {
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "number"
                        }
                    }
                }
            }
        },
        "tests": [
            {
                "description": "valid nested array",
                "data": [[[[1]], [[2],[3]]], [[[4], [5], [6]]]],
                "valid": true,
                "id": "eb61fa50a763c7cf2b7b5193177dca4c"
            },
            {
                "description": "nested array with invalid type",
                "data": [[[["1"]], [[2],[3]]], [[[4], [5], [6]]]],
                "valid": false,
                "id": "5a02e6440b2e907d71c4847a793a7eb8"
            },
            {
                "description": "not deep enough",
                "data": [[[1], [2],[3]], [[4], [5], [6]]],
                "valid": false,
                "id": "52d71edac2f2dc8c1badee77605aaf92"
            }
        ]
    },
    {
        "description": "single-form items with null instance elements",
        "schema": {
            "items": {
                "type": "null"
            }
        },
        "tests": [
            {
                "description": "allows null elements",
                "data": [ null ],
                "valid": true,
                "id": "2ea257f9daca0b647d1ddcb1eb9e66d8"
            }
        ]
    },
    {
        "description": "array-form items with null instance elements",
        "schema": {
            "items": [
                {
                    "type": "null"
                }
            ]
        },
        "tests": [
            {
                "description": "allows null elements",
                "data": [ null ],
                "valid": true,
                "id": "0690333ed1dd8a5045d7f346da528c35"
            }
        ]
    }
]
