[
    {
        "description": "contains keyword validation",
        "schema": {
            "contains": {"minimum": 5}
        },
        "tests": [
            {
                "description": "array with item matching schema (5) is valid",
                "data": [3, 4, 5],
                "valid": true,
                "id": "fad1fdaded12740a1c733c44df19ddb0"
            },
            {
                "description": "array with item matching schema (6) is valid",
                "data": [3, 4, 6],
                "valid": true,
                "id": "41dbf932f275be67fe886e0d240f86f5"
            },
            {
                "description": "array with two items matching schema (5, 6) is valid",
                "data": [3, 4, 5, 6],
                "valid": true,
                "id": "75c4f56a826deafd14dc9a8e3827c665"
            },
            {
                "description": "array without items matching schema is invalid",
                "data": [2, 3, 4],
                "valid": false,
                "id": "1c4da9ab64d6be719bc3d4cd0cd75f36"
            },
            {
                "description": "empty array is invalid",
                "data": [],
                "valid": false,
                "id": "5272b380da134d7351af87c9e37d9b8f"
            },
            {
                "description": "not array is valid",
                "data": {},
                "valid": true,
                "id": "5c42d7258c3a1f084fc6b3022ea59955"
            }
        ]
    },
    {
        "description": "contains keyword with const keyword",
        "schema": {
            "contains": { "const": 5 }
        },
        "tests": [
            {
                "description": "array with item 5 is valid",
                "data": [3, 4, 5],
                "valid": true,
                "id": "1049666c7795c28953a8fc6f34dbe805"
            },
            {
                "description": "array with two items 5 is valid",
                "data": [3, 4, 5, 5],
                "valid": true,
                "id": "5e9e0c50c1a048f00f7b18dcb84be6d2"
            },
            {
                "description": "array without item 5 is invalid",
                "data": [1, 2, 3, 4],
                "valid": false,
                "id": "f79e8855bd33db31c351982ee610d23c"
            }
        ]
    },
    {
        "description": "contains keyword with boolean schema true",
        "schema": {"contains": true},
        "tests": [
            {
                "description": "any non-empty array is valid",
                "data": ["foo"],
                "valid": true,
                "id": "23e0c6ec12a2d8354a7f044735424be7"
            },
            {
                "description": "empty array is invalid",
                "data": [],
                "valid": false,
                "id": "b2361c11fa8eeb27ab614795364978c6"
            }
        ]
    },
    {
        "description": "contains keyword with boolean schema false",
        "schema": {"contains": false},
        "tests": [
            {
                "description": "any non-empty array is invalid",
                "data": ["foo"],
                "valid": false,
                "id": "849d9ca8ebce408d0b3e52e45b81906f"
            },
            {
                "description": "empty array is invalid",
                "data": [],
                "valid": false,
                "id": "f8a3b07fb26badb81295ef359cf081a9"
            },
            {
                "description": "non-arrays are valid",
                "data": "contains does not apply to strings",
                "valid": true,
                "id": "7510f87da571e6244535b8682834f271"
            }
        ]
    },
    {
        "description": "items + contains",
        "schema": {
            "items": { "multipleOf": 2 },
            "contains": { "multipleOf": 3 }
        },
        "tests": [
            {
                "description": "matches items, does not match contains",
                "data": [ 2, 4, 8 ],
                "valid": false,
                "id": "63786b8fdd4a9855d0df2b15759ec321"
            },
            {
                "description": "does not match items, matches contains",
                "data": [ 3, 6, 9 ],
                "valid": false,
                "id": "7036b0a021ef984b94a8bbc4631dda28"
            },
            {
                "description": "matches both items and contains",
                "data": [ 6, 12 ],
                "valid": true,
                "id": "595325df776428ff22b0f730660e0d51"
            },
            {
                "description": "matches neither items nor contains",
                "data": [ 1, 5 ],
                "valid": false,
                "id": "7bed55150fb14040259ed1b7863b92c1"
            }
        ]
    },
    {
        "description": "contains with false if subschema",
        "schema": {
            "contains": {
                "if": false,
                "else": true
            }
        },
        "tests": [
            {
                "description": "any non-empty array is valid",
                "data": ["foo"],
                "valid": true,
                "id": "7f879e1005f98b1bddfca77cc3f7c5ed"
            },
            {
                "description": "empty array is invalid",
                "data": [],
                "valid": false,
                "id": "a8728a11f94d069b9b8e42162cca2f8b"
            }
        ]
    },
    {
        "description": "contains with null instance elements",
        "schema": {
            "contains": {
                "type": "null"
            }
        },
        "tests": [
            {
                "description": "allows null items",
                "data": [ null ],
                "valid": true,
                "id": "12a822cd18d1ee86416b853e57bf9432"
            }
        ]
    }
]
