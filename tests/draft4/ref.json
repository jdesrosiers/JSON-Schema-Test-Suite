[
    {
        "description": "root pointer ref",
        "schema": {
            "properties": {
                "foo": {"$ref": "#"}
            },
            "additionalProperties": false
        },
        "tests": [
            {
                "description": "match",
                "data": {"foo": false},
                "valid": true,
                "id": "2709607549a158a4590a022b6129cf30"
            },
            {
                "description": "recursive match",
                "data": {"foo": {"foo": false}},
                "valid": true,
                "id": "6971685c73d35a737af9e786d2403432"
            },
            {
                "description": "mismatch",
                "data": {"bar": false},
                "valid": false,
                "id": "4f9b6347e034432c86cb5de73f98da41"
            },
            {
                "description": "recursive mismatch",
                "data": {"foo": {"bar": false}},
                "valid": false,
                "id": "f443736d72338f1fd49f4c2549552969"
            }
        ]
    },
    {
        "description": "relative pointer ref to object",
        "schema": {
            "properties": {
                "foo": {"type": "integer"},
                "bar": {"$ref": "#/properties/foo"}
            }
        },
        "tests": [
            {
                "description": "match",
                "data": {"bar": 3},
                "valid": true,
                "id": "814a44012c2f066fb3b5c627136aec22"
            },
            {
                "description": "mismatch",
                "data": {"bar": true},
                "valid": false,
                "id": "031da3a44198f011c43fd0a8b7b6177a"
            }
        ]
    },
    {
        "description": "relative pointer ref to array",
        "schema": {
            "items": [
                {"type": "integer"},
                {"$ref": "#/items/0"}
            ]
        },
        "tests": [
            {
                "description": "match array",
                "data": [1, 2],
                "valid": true,
                "id": "8f2890916a640a0e138b3b8021537cc7"
            },
            {
                "description": "mismatch array",
                "data": [1, "foo"],
                "valid": false,
                "id": "2e78527b71a53a8c8ec0d03c9640d620"
            }
        ]
    },
    {
        "description": "escaped pointer ref",
        "schema": {
            "definitions": {
                "tilde~field": {"type": "integer"},
                "slash/field": {"type": "integer"},
                "percent%field": {"type": "integer"}
            },
            "properties": {
                "tilde": {"$ref": "#/definitions/tilde~0field"},
                "slash": {"$ref": "#/definitions/slash~1field"},
                "percent": {"$ref": "#/definitions/percent%25field"}
            }
        },
        "tests": [
            {
                "description": "slash invalid",
                "data": {"slash": "aoeu"},
                "valid": false,
                "id": "5995de8b190f01d2f827f8a288be453d"
            },
            {
                "description": "tilde invalid",
                "data": {"tilde": "aoeu"},
                "valid": false,
                "id": "b9939ff3f4177fd9a0eed7955666388a"
            },
            {
                "description": "percent invalid",
                "data": {"percent": "aoeu"},
                "valid": false,
                "id": "55c525ae808e4bb3c7d6b4a934a41855"
            },
            {
                "description": "slash valid",
                "data": {"slash": 123},
                "valid": true,
                "id": "623c18da7321a110344778c62d7a3417"
            },
            {
                "description": "tilde valid",
                "data": {"tilde": 123},
                "valid": true,
                "id": "687a770517f8d82d699793676d738412"
            },
            {
                "description": "percent valid",
                "data": {"percent": 123},
                "valid": true,
                "id": "d52be423e8a71475d33440bcbb475faa"
            }
        ]
    },
    {
        "description": "nested refs",
        "schema": {
            "definitions": {
                "a": {"type": "integer"},
                "b": {"$ref": "#/definitions/a"},
                "c": {"$ref": "#/definitions/b"}
            },
            "allOf": [{ "$ref": "#/definitions/c" }]
        },
        "tests": [
            {
                "description": "nested ref valid",
                "data": 5,
                "valid": true,
                "id": "2c102d8f652c56be1ed2a1aadc9212a8"
            },
            {
                "description": "nested ref invalid",
                "data": "a",
                "valid": false,
                "id": "8317f37595db5777c82cc4de1885638b"
            }
        ]
    },
    {
        "description": "ref overrides any sibling keywords",
        "schema": {
            "definitions": {
                "reffed": {
                    "type": "array"
                }
            },
            "properties": {
                "foo": {
                    "$ref": "#/definitions/reffed",
                    "maxItems": 2
                }
            }
        },
        "tests": [
            {
                "description": "ref valid",
                "data": { "foo": [] },
                "valid": true,
                "id": "55bc9c19d42477f4f14509c943da6cb3"
            },
            {
                "description": "ref valid, maxItems ignored",
                "data": { "foo": [ 1, 2, 3] },
                "valid": true,
                "id": "a5009470130eea6a6bf1397cb7b5cc9c"
            },
            {
                "description": "ref invalid",
                "data": { "foo": "string" },
                "valid": false,
                "id": "ea7793c46ceb182719da50cab8dbf997"
            }
        ]
    },
    {
        "description": "$ref prevents a sibling id from changing the base uri",
        "schema": {
            "id": "http://localhost:1234/sibling_id/base/",
            "definitions": {
                "foo": {
                    "id": "http://localhost:1234/sibling_id/foo.json",
                    "type": "string"
                },
                "base_foo": {
                    "$comment": "this canonical uri is http://localhost:1234/sibling_id/base/foo.json",
                    "id": "foo.json",
                    "type": "number"
                }
            },
            "allOf": [
                {
                    "$comment": "$ref resolves to http://localhost:1234/sibling_id/base/foo.json, not http://localhost:1234/sibling_id/foo.json",
                    "id": "http://localhost:1234/sibling_id/",
                    "$ref": "foo.json"
                }
            ]
        },
        "tests": [
            {
                "description": "$ref resolves to /definitions/base_foo, data does not validate",
                "data": "a",
                "valid": false,
                "id": "98264acf0a888fd602ae50c218d9de77"
            },
            {
                "description": "$ref resolves to /definitions/base_foo, data validates",
                "data": 1,
                "valid": true,
                "id": "4897a99f8e1539248033aeaa04879da8"
            }
        ]
    },
    {
