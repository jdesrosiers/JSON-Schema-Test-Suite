[
    {
        "description": "allOf",
        "schema": {
            "allOf": [
                {
                    "properties": {
                        "bar": {"type": "integer"}
                    },
                    "required": ["bar"]
                },
                {
                    "properties": {
                        "foo": {"type": "string"}
                    },
                    "required": ["foo"]
                }
            ]
        },
        "tests": [
            {
                "description": "allOf",
                "data": {"foo": "baz", "bar": 2},
                "valid": true,
                "id": "cabde26d49c378e7115610e445105909"
            },
            {
                "description": "mismatch second",
                "data": {"foo": "baz"},
                "valid": false,
                "id": "f9b15a4f2bcf6f8f8be0eed4e7beb36a"
            },
            {
                "description": "mismatch first",
                "data": {"bar": 2},
                "valid": false,
                "id": "54787f62df3b4fc50f0e970deb3043a6"
            },
            {
                "description": "wrong type",
                "data": {"foo": "baz", "bar": "quux"},
                "valid": false,
                "id": "11409e42b88caad9ed607a5049423231"
            }
        ]
    },
    {
        "description": "allOf with base schema",
        "schema": {
            "properties": {"bar": {"type": "integer"}},
            "required": ["bar"],
            "allOf" : [
                {
                    "properties": {
                        "foo": {"type": "string"}
                    },
                    "required": ["foo"]
                },
                {
                    "properties": {
                        "baz": {"type": "null"}
                    },
                    "required": ["baz"]
                }
            ]
        },
        "tests": [
            {
                "description": "valid",
                "data": {"foo": "quux", "bar": 2, "baz": null},
                "valid": true,
                "id": "07a8049163d5f7612022191b2c49d580"
            },
            {
                "description": "mismatch base schema",
                "data": {"foo": "quux", "baz": null},
                "valid": false,
                "id": "5fa8fb333bfe4390f67fa1fbc5c98160"
            },
            {
                "description": "mismatch first allOf",
                "data": {"bar": 2, "baz": null},
                "valid": false,
                "id": "70fe54ab93b438f24d2fb02ca5a2f534"
            },
            {
                "description": "mismatch second allOf",
                "data": {"foo": "quux", "bar": 2},
                "valid": false,
                "id": "ce8873c336b7f48b99c583aca8285880"
            },
            {
                "description": "mismatch both",
                "data": {"bar": 2},
                "valid": false,
                "id": "e86599b5e55940f4abc1aec4ddb681ae"
            }
        ]
    },
