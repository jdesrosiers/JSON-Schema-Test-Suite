        ]
    },
    {
        "description": "oneOf with required",
        "schema": {
            "type": "object",
            "oneOf": [
                { "required": ["foo", "bar"] },
                { "required": ["foo", "baz"] }
            ]
        },
        "tests": [
            {
                "description": "both invalid - invalid",
                "data": {"bar": 2},
                "valid": false,
                "id": "d10de0d48cec99a685b6d0c26325b41d"
            },
            {
                "description": "first valid - valid",
                "data": {"foo": 1, "bar": 2},
                "valid": true,
                "id": "1fee55c6a259a5f6c1620dbb40ae97c5"
            },
            {
                "description": "second valid - valid",
                "data": {"foo": 1, "baz": 3},
                "valid": true,
                "id": "15e607317e834dbf18b12298bdf076ba"
            },
            {
                "description": "both valid - invalid",
                "data": {"foo": 1, "bar": 2, "baz" : 3},
                "valid": false,
                "id": "0f5778a05ed4754d5834e09a8e3946bb"
            }
        ]
    },
    {
