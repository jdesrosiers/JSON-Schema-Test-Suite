    {
        "description": "invalid type for default",
        "schema": {
            "properties": {
                "foo": {
                    "type": "integer",
                    "default": []
                }
            }
        },
        "tests": [
            {
                "description": "valid when property is specified",
                "data": {"foo": 13},
                "valid": true,
                "id": "de9388ac97ab335f978a169482a5ae31"
            },
            {
                "description": "still valid when the invalid default is used",
                "data": {},
                "valid": true,
                "id": "bf8186aae9698c83c2cfc4bf53645b0c"
            }
        ]
    },
    {
        "description": "invalid string value for default",
        "schema": {
            "properties": {
                "bar": {
                    "type": "string",
                    "minLength": 4,
                    "default": "bad"
                }
            }
        },
        "tests": [
            {
                "description": "valid when property is specified",
                "data": {"bar": "good"},
                "valid": true,
                "id": "50479a82893887340ecad26d2b51f9e7"
            },
            {
                "description": "still valid when the invalid default is used",
                "data": {},
                "valid": true,
                "id": "53a71c28a9d4272bc06cac9efc13e319"
            }
        ]
    },
    {
        "description": "the default keyword does not do anything if the property is missing",
        "schema": {
            "type": "object",
            "properties": {
                "alpha": {
                    "type": "number",
                    "maximum": 3,
                    "default": 5
                }
            }
        },
        "tests": [
            {
                "description": "an explicit property value is checked against maximum (passing)",
                "data": { "alpha": 1 },
                "valid": true,
                "id": "c6059b9b978427ab501dcc06bca6132e"
            },
            {
                "description": "an explicit property value is checked against maximum (failing)",
                "data": { "alpha": 5 },
                "valid": false,
                "id": "455c52d1b674110bb434d2970877c645"
            },
            {
                "description": "missing properties are not filled in with the default",
                "data": {},
                "valid": true,
                "id": "b5be2e5652fffaee92de0dded32cd064"
            }
        ]
    }
]
