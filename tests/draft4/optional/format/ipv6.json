                "id": "d5eb9d26f51e09e72159d8392cea1650"
            },
            {
                "description": "two sets of double colons is invalid",
                "data": "1::d6::42",
                "valid": false,
                "id": "122305de6886ade125b0669f334de2ce"
            },
            {
                "description": "mixed format with the ipv4 section as decimal octets",
