                "valid": false,
                "id": "ba5a1664f3273399d94d2d560b562ea7"
            },
            {
                "description": "mixed format with ipv4 section with a hex octet",
                "data": "1::2:192.168.ff.1",
                "valid": false,
                "id": "ff4f88bb699e86a1418b69ce71b79421"
            },
            {
                "description": "mixed format with leading double colons (ipv4-mapped ipv6 address)",
                "data": "::ffff:192.168.0.1",
                "valid": true,
                "id": "12a078f87018fc5a06f303c526086142"
            },
            {
                "description": "triple colons is invalid",
                "data": "1:2:3:4:5:::8",
                "valid": false,
                "id": "b320eb368b4a31fc772fd8564208a2f0"
            },
            {
                "description": "8 octets",
                "data": "1:2:3:4:5:6:7:8",
                "valid": true,
                "id": "50018049606a65908431ac445d9a4ae5"
            },
            {
                "description": "insufficient octets without double colons",
                "data": "1:2:3:4:5:6:7",
                "valid": false,
                "id": "12e0e3fc52500fab4d9fc46e51371bd1"
            },
            {
                "description": "no colons is invalid",
                "data": "1",
                "valid": false,
                "id": "5d970adc300992b973cba192c631c003"
            },
            {
                "description": "ipv4 is not ipv6",
                "data": "127.0.0.1",
                "valid": false,
                "id": "6e5435acd876c6bc8d584e8fbef3ebd5"
            },
            {
                "description": "ipv4 segment must have 4 octets",
                "data": "1:2:3:4:1.2.3",
                "valid": false,
                "id": "3639f6a0bc3113735d949ccd2e2a9441"
            },
            {
                "description": "leading whitespace is invalid",
                "data": "  ::1",
                "valid": false,
                "id": "5626da49c949a73f05a384a2b731f6e6"
            },
            {
                "description": "trailing whitespace is invalid",
                "data": "::1  ",
                "valid": false,
                "id": "ab1b39a8d67e47735c2bd56fc14c9c0d"
            },
            {
                "description": "netmask is not a part of ipv6 address",
                "data": "fe80::/64",
                "valid": false,
                "id": "c72946639993760756c4b79354becbda"
            },
            {
                "description": "zone id is not a part of ipv6 address",
                "data": "fe80::a%eth1",
                "valid": false,
                "id": "37ff10fc5a4bcb0b45bc3f600bb45c38"
            },
            {
                "description": "a long valid ipv6",
                "data": "1000:1000:1000:1000:1000:1000:255.255.255.255",
