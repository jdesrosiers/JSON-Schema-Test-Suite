[
    {
        "description": "contains keyword validation",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "contains": { "minimum": 5 }
        },
        "tests": [
            {
                "description": "array with item matching schema (5) is valid",
                "data": [3, 4, 5],
                "valid": true,
                "id": "32580ef4c12b0fa1411d449b86bd152b"
            },
            {
                "description": "array with item matching schema (6) is valid",
                "data": [3, 4, 6],
                "valid": true,
                "id": "35e75ea3af79af10ff38762922e90088"
            },
            {
                "description": "array with two items matching schema (5, 6) is valid",
                "data": [3, 4, 5, 6],
                "valid": true,
                "id": "4f51728f37db2cdd21ffa7ca3b1d46a3"
            },
            {
                "description": "array without items matching schema is invalid",
                "data": [2, 3, 4],
                "valid": false,
                "id": "4baa1e7185dda1dc9978a7796ed7db40"
            },
            {
                "description": "empty array is invalid",
                "data": [],
                "valid": false,
                "id": "b5f4f7c7f08b1f0f7ea865810f1325c2"
            },
            {
                "description": "not array or object is valid",
                "data": 42,
                "valid": true,
                "id": "63a2bb13fbb552d8f8819a51b820b7fd"
            }
        ]
    },
    {
        "description": "contains keyword with const keyword",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "contains": { "const": 5 }
        },
        "tests": [
            {
                "description": "array with item 5 is valid",
                "data": [3, 4, 5],
                "valid": true,
                "id": "e62d900995d6e07b662ec44fda60d5ef"
            },
            {
                "description": "array with two items 5 is valid",
                "data": [3, 4, 5, 5],
                "valid": true,
                "id": "8a6e33742341d6b8d3039e3e7b8b5afd"
            },
            {
                "description": "array without item 5 is invalid",
                "data": [1, 2, 3, 4],
                "valid": false,
                "id": "3aa3e8ca86364bea05ae90f51fc7a148"
            }
        ]
    },
    {
        "description": "contains keyword with boolean schema true",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "contains": true
        },
        "tests": [
            {
                "description": "any non-empty array is valid",
                "data": ["foo"],
                "valid": true,
                "id": "dad8c6e7263735ac85d66e5d3e8fae7b"
            },
            {
                "description": "empty array is invalid",
                "data": [],
                "valid": false,
                "id": "19237f80d4add8ab98d7c0b84686c44f"
            }
        ]
    },
    {
        "description": "contains keyword with boolean schema false",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "contains": false
        },
        "tests": [
            {
                "description": "any non-empty array is invalid",
                "data": ["foo"],
                "valid": false,
                "id": "8895842a973da4eb062b3cdabb62b342"
            },
            {
                "description": "empty array is invalid",
                "data": [],
                "valid": false,
                "id": "df0e334e0c8676371c1d537bf9913624"
            },
            {
                "description": "non-arrays are valid - string",
                "data": "contains does not apply to strings",
                "valid": true,
                "id": "bce3cceb0c98b14609375bef5026e6dc"
            },
            {
                "description": "non-arrays are valid - object",
                "data": {},
                "valid": true,
                "id": "69ca85509440f599b252433c62a91ecf"
            },
            {
                "description": "non-arrays are valid - number",
                "data": 42,
                "valid": true,
                "id": "994a4ac253c9fc68ae6a13d42024a1af"
            },
            {
                "description": "non-arrays are valid - boolean",
                "data": false,
                "valid": true,
                "id": "96cd8f17b6675b1dbd242deaa83798da"
            },
            {
                "description": "non-arrays are valid - null",
                "data": null,
                "valid": true,
                "id": "7318ade55aa7923a273463ee41471407"
            }
        ]
    },
    {
        "description": "items + contains",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "additionalProperties": { "multipleOf": 2 },
            "items": { "multipleOf": 2 },
            "contains": { "multipleOf": 3 }
        },
        "tests": [
            {
                "description": "matches items, does not match contains",
                "data": [2, 4, 8],
                "valid": false,
                "id": "b0ed6ea80a1e70e5b8027f4a7a33874b"
            },
            {
                "description": "does not match items, matches contains",
                "data": [3, 6, 9],
                "valid": false,
                "id": "3efb014d3c482c5ea0f2bdc7517ed5d9"
            },
            {
                "description": "matches both items and contains",
                "data": [6, 12],
                "valid": true,
                "id": "15bc96a5fbf407b671edc2115d86b24d"
            },
            {
                "description": "matches neither items nor contains",
                "data": [1, 5],
                "valid": false,
                "id": "25d12173c809045b3b4291099e2eb2a2"
            }
        ]
    },
    {
        "description": "contains with false if subschema",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "contains": {
                "if": false,
                "else": true
            }
        },
        "tests": [
            {
                "description": "any non-empty array is valid",
                "data": ["foo"],
                "valid": true,
                "id": "f308a0408bdd653b8fb177d2683197ee"
            },
            {
                "description": "empty array is invalid",
                "data": [],
                "valid": false,
                "id": "a92ba446b7933f64660f64e8f5029a83"
            }
        ]
    },
    {
        "description": "contains with null instance elements",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "contains": {
                "type": "null"
            }
        },
        "tests": [
            {
                "description": "allows null items",
                "data": [ null ],
                "valid": true,
                "id": "dadd708e334e385b0688e7e414da9a73"
            }
        ]
    }
]
