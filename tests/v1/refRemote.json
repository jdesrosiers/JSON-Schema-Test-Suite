    {
        "description": "retrieved nested refs resolve relative to their URI not $id",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "$id": "http://localhost:1234/v1/some-id",
            "properties": {
                "name": {"$ref": "nested/foo-ref-string.json"}
            }
        },
        "tests": [
            {
                "description": "number is invalid",
                "data": {
                    "name": {"foo":  1}
                },
                "valid": false,
                "id": "806dc6a0387a84044924046682483cda"
            },
            {
                "description": "string is valid",
                "data": {
                    "name": {"foo":  "a"}
                },
                "valid": true,
                "id": "17a8e79236fee3e4eab68d6fc6c09e60"
