[
    {
        "description": "unevaluatedProperties can see inside propertyDependencies",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "properties": {
                "foo": {
                    "type": "string"
                }
            },
            "propertyDependencies": {
                "foo": {
                    "foo1": {
                        "properties": {
                            "bar": true
                        }
                    }
                }
            },
            "unevaluatedProperties": false
        },
        "tests": [
            {
                "description": "allows bar if foo = foo1",
                "data": {
                    "foo": "foo1",
                    "bar": 42
                },
                "valid": true,
                "id": "a7614510fe1d7fae2c61aa066abb57d9"
            },
            {
                "description": "disallows bar if foo != foo1",
                "data": {
                    "foo": "foo2",
                    "bar": 42
                },
                "valid": false,
                "id": "bd54523ddb6a7c3036654573ed7ebf4b"
            },
            {
                "description": "disallows bar if foo is absent",
                "data": {
                    "bar": 42
                },
                "valid": false,
                "id": "94c797a170ed22ffbe539e172b855deb"
            }
        ]
    },
    {
        "description": "propertyDependencies with unevaluatedProperties" ,
        "schema" : {
            "$schema": "https://json-schema.org/v1",
            "properties" : {"foo2" : {}},
            "propertyDependencies": {
                "foo" : {},
                "foo2": {
                    "bar": {
                        "properties": {
                            "buz": {}
                        }
                    }
                }
            },
            "unevaluatedProperties": false
        },

        "tests": [
            {
                "description": "unevaluatedProperties doesn't consider propertyDependencies" , 
                "data": {"foo": "bar"},
                "valid": false,
                "id": "b5df12adc3c226373963f8ae6d8ef8e0"
            },
            {
                "description": "unevaluatedProperties sees buz when foo2 is present",
                "data": {"foo2": "bar", "buz": ""},
                "valid": true,
                "id": "ab5d4506d35874d28acdbdf59ce265e4"
            },
            {
                "description": "unevaluatedProperties doesn't see buz when foo2 is absent",
                "data": {"buz": ""},
                "valid": false,
                "id": "f38bf24a64cd381221eb56bfa986845f"
            }
        ]
    }
]
