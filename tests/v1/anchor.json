    {
        "description": "same $anchor with different base uri",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "$id": "http://localhost:1234/v1/foobar",
            "$defs": {
                "A": {
                    "$id": "child1",
                    "allOf": [
                        {
                            "$id": "child2",
                            "$anchor": "my_anchor",
                            "type": "number"
                        },
                        {
                            "$anchor": "my_anchor",
                            "type": "string"
                        }
                    ]
                }
            },
            "$ref": "child1#my_anchor"
        },
        "tests": [
            {
                "description": "$ref resolves to /$defs/A/allOf/1",
                "data": "a",
                "valid": true,
                "id": "64253c6ffd2775dd616723f84ff29630"
            },
            {
                "description": "$ref does not resolve to /$defs/A/allOf/0",
                "data": 1,
                "valid": false,
                "id": "f2d3fc465bf1ba8fbfe19c05dd9e535f"
            }
        ]
    }
]
