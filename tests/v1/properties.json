[
    {
        "description": "object properties validation",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "properties": {
                "foo": {"type": "integer"},
                "bar": {"type": "string"}
            }
        },
        "tests": [
            {
                "description": "both properties present and valid is valid",
                "data": {"foo": 1, "bar": "baz"},
                "valid": true,
                "id": "d7134e2869ca7ecc0cdef844fd114491"
            },
            {
                "description": "one property invalid is invalid",
                "data": {"foo": 1, "bar": {}},
                "valid": false,
                "id": "cad81128e9aebb998ae0690b432a55f5"
            },
            {
                "description": "both properties invalid is invalid",
                "data": {"foo": [], "bar": {}},
                "valid": false,
                "id": "dea58a4f43b7a7d855ce1d85c57af615"
            },
            {
                "description": "doesn't invalidate other properties",
                "data": {"quux": []},
                "valid": true,
                "id": "15a332477ec01e8befe291819ed1bb27"
            },
            {
                "description": "ignores arrays",
                "data": [],
                "valid": true,
                "id": "37204e85a192adeac06b9b633ba0df48"
            },
            {
                "description": "ignores other non-objects",
                "data": 12,
                "valid": true,
                "id": "ac757fd1a8b213804cfdeb5a2941cd87"
            }
        ]
    },
    {
        "description":
            "properties, patternProperties, additionalProperties interaction",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "properties": {
                "foo": {"type": "array", "maxItems": 3},
                "bar": {"type": "array"}
            },
            "patternProperties": {"f.o": {"minItems": 2}},
            "additionalProperties": {"type": "integer"}
        },
        "tests": [
            {
                "description": "property validates property",
                "data": {"foo": [1, 2]},
                "valid": true,
                "id": "b6c210885c0cd2e771b213ff63ca7b3b"
            },
            {
                "description": "property invalidates property",
                "data": {"foo": [1, 2, 3, 4]},
                "valid": false,
                "id": "0f7bc6e60347f5e93b3ca7abaf983891"
            },
            {
                "description": "patternProperty invalidates property",
                "data": {"foo": []},
                "valid": false,
                "id": "5230c24fdc88dbbd8c529d88b065da9f"
            },
            {
                "description": "patternProperty validates nonproperty",
                "data": {"fxo": [1, 2]},
                "valid": true,
                "id": "f93ed9554aaf49f3f1833c4c315bff8d"
            },
            {
                "description": "patternProperty invalidates nonproperty",
                "data": {"fxo": []},
                "valid": false,
                "id": "2db6e344432105f241e2eb2e9ad0a3c7"
            },
            {
                "description": "additionalProperty ignores property",
                "data": {"bar": []},
                "valid": true,
                "id": "86c65309eb5b7a3331a1503d55a97f29"
            },
            {
                "description": "additionalProperty validates others",
                "data": {"quux": 3},
                "valid": true,
                "id": "e0087ad6ab647a8f82789af55bd85608"
            },
            {
                "description": "additionalProperty invalidates others",
                "data": {"quux": "foo"},
                "valid": false,
                "id": "7c3fb36c146e0802e71545f3fd6835de"
            }
        ]
    },
    {
        "description": "properties with boolean schema",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "properties": {
                "foo": true,
                "bar": false
            }
        },
        "tests": [
            {
                "description": "no property present is valid",
                "data": {},
                "valid": true,
                "id": "1c6c20c8f094e08cedf169c951bcccc6"
            },
            {
                "description": "only 'true' property present is valid",
                "data": {"foo": 1},
                "valid": true,
                "id": "0fd656472d80e94b3828e4621889d786"
            },
            {
                "description": "only 'false' property present is invalid",
                "data": {"bar": 2},
                "valid": false,
                "id": "c40d058c51d537a1b50c430a9f4f4c7f"
            },
            {
                "description": "both properties present is invalid",
                "data": {"foo": 1, "bar": 2},
                "valid": false,
                "id": "e85265a5f93593709090bddcca2eccd9"
            }
        ]
    },
    {
        "description": "properties with escaped characters",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "properties": {
                "foo\nbar": {"type": "number"},
                "foo\"bar": {"type": "number"},
                "foo\\bar": {"type": "number"},
                "foo\rbar": {"type": "number"},
                "foo\tbar": {"type": "number"},
                "foo\fbar": {"type": "number"}
            }
        },
        "tests": [
            {
                "description": "object with all numbers is valid",
                "data": {
                    "foo\nbar": 1,
                    "foo\"bar": 1,
                    "foo\\bar": 1,
                    "foo\rbar": 1,
                    "foo\tbar": 1,
                    "foo\fbar": 1
                },
                "valid": true,
                "id": "d786d3ad47595666bc45a1b2d8568b83"
            },
            {
                "description": "object with strings is invalid",
                "data": {
                    "foo\nbar": "1",
                    "foo\"bar": "1",
                    "foo\\bar": "1",
                    "foo\rbar": "1",
                    "foo\tbar": "1",
                    "foo\fbar": "1"
                },
                "valid": false,
                "id": "83892f2d4e47aa1ff181f6f5b3570172"
            }
        ]
    },
    {
        "description": "properties with null valued instance properties",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "properties": {
                "foo": {"type": "null"}
            }
        },
        "tests": [
            {
                "description": "allows null values",
                "data": {"foo": null},
                "valid": true,
                "id": "6672d24c5cd807f76577aa237175e9ae"
            }
        ]
    },
    {
        "description": "properties whose names are Javascript object property names",
        "comment": "Ensure JS implementations don't universally consider e.g. __proto__ to always be present in an object.",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "properties": {
                "__proto__": {"type": "number"},
                "toString": {
                    "properties": { "length": { "type": "string" } }
                },
                "constructor": {"type": "number"}
            }
        },
        "tests": [
            {
                "description": "ignores arrays",
                "data": [],
                "valid": true,
                "id": "c1ca86c5836fd09dd4c5f4e2c8dc52e6"
            },
            {
                "description": "ignores other non-objects",
                "data": 12,
                "valid": true,
                "id": "df78d45837e97bb392d7ed57ce6b1b87"
            },
            {
                "description": "none of the properties mentioned",
                "data": {},
                "valid": true,
                "id": "1fa7dbe33ee7154a7d13853f724ac7ab"
            },
            {
                "description": "__proto__ not valid",
                "data": { "__proto__": "foo" },
                "valid": false,
                "id": "fc6342bd5b3d7671a518469e80a5670c"
            },
            {
                "description": "toString not valid",
                "data": { "toString": { "length": 37 } },
                "valid": false,
                "id": "deef5020d9101e384ba68f99fe4fd7e3"
            },
            {
                "description": "constructor not valid",
                "data": { "constructor": { "length": 37 } },
                "valid": false,
                "id": "f0eac52f2949892de2f72377afcfc7bd"
            },
            {
                "description": "all present and valid",
                "data": { 
                    "__proto__": 12,
                    "toString": { "length": "foo" },
                    "constructor": 37
                },
                "valid": true,
                "id": "4bc1661456543220d9921393087ab44b"
            }
        ]
    }
]
