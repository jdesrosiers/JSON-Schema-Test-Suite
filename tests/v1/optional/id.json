[
    {
        "description": "$id inside an enum is not a real identifier",
        "comment": "the implementation must not be confused by an $id buried in the enum",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "$defs": {
                "id_in_enum": {
                    "enum": [
                        {
                          "$id": "https://localhost:1234/v1/id/my_identifier.json",
                          "type": "null"
                        }
                    ]
                },
                "real_id_in_schema": {
                    "$id": "https://localhost:1234/v1/id/my_identifier.json",
                    "type": "string"
                },
                "zzz_id_in_const": {
                    "const": {
                        "$id": "https://localhost:1234/v1/id/my_identifier.json",
                        "type": "null"
                    }
                }
            },
            "anyOf": [
                { "$ref": "#/$defs/id_in_enum" },
                { "$ref": "https://localhost:1234/v1/id/my_identifier.json" }
            ]
        },
        "tests": [
            {
                "description": "exact match to enum, and type matches",
                "data": {
                    "$id": "https://localhost:1234/v1/id/my_identifier.json",
                    "type": "null"
                },
                "valid": true,
                "id": "74493a6a2393ef2e3834d6e5d6e564a1"
            },
            {
                "description": "match $ref to $id",
                "data": "a string to match #/$defs/id_in_enum",
                "valid": true,
                "id": "d45b23f3a6ca536447d46fd630493f52"
            },
            {
                "description": "no match on enum or $ref to $id",
                "data": 1,
                "valid": false,
                "id": "77c468828a4fd2737e9aff669ba30df1"
            }
        ]
    }
]
