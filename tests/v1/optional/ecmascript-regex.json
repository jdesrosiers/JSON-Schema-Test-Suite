[
    {
        "description": "ECMA 262 regex $ does not match trailing newline",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "type": "string",
            "pattern": "^abc$"
        },
        "tests": [
            {
                "description": "matches in Python, but not in ECMA 262",
                "data": "abc\\n",
                "valid": false,
                "id": "9579e877c6f3863fae63bb8672f4f964"
            },
            {
                "description": "matches",
                "data": "abc",
                "valid": true,
                "id": "b80dd2f0268225a5bb66130f01a6fe62"
            }
        ]
    },
    {
        "description": "ECMA 262 regex converts \\t to horizontal tab",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "type": "string",
            "pattern": "^\\t$"
        },
        "tests": [
            {
                "description": "does not match",
                "data": "\\t",
                "valid": false,
                "id": "d04cf1f09b37c7b0ed68fe4057ae5e14"
            },
            {
                "description": "matches",
                "data": "\u0009",
                "valid": true,
                "id": "ff6625ef613ca56f94bb2fdbd33659b3"
            }
        ]
    },
    {
        "description": "ECMA 262 regex escapes control codes with \\c and upper letter",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "type": "string",
            "pattern": "^\\cC$"
        },
        "tests": [
            {
                "description": "does not match",
                "data": "\\cC",
                "valid": false,
                "id": "5d9709d79bb67ef515b1aa8512bf1486"
            },
            {
                "description": "matches",
                "data": "\u0003",
                "valid": true,
                "id": "fa00e76ec674f4f2eb217caa38f1ba37"
            }
        ]
    },
    {
        "description": "ECMA 262 regex escapes control codes with \\c and lower letter",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "type": "string",
            "pattern": "^\\cc$"
        },
        "tests": [
            {
                "description": "does not match",
                "data": "\\cc",
                "valid": false,
                "id": "f467af7daadb5d6f90706f360bab13b2"
            },
            {
                "description": "matches",
                "data": "\u0003",
                "valid": true,
                "id": "3a31b8b233f39bc5b8d7cd1fb0796af7"
            }
        ]
    },
    {
        "description": "ECMA 262 \\d matches ascii digits only",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "type": "string",
            "pattern": "^\\d$"
        },
        "tests": [
            {
                "description": "ASCII zero matches",
                "data": "0",
                "valid": true,
                "id": "55e5c3b50938a6fdfd349a25adb5b088"
            },
            {
                "description": "NKO DIGIT ZERO does not match (unlike e.g. Python)",
                "data": "߀",
                "valid": false,
                "id": "df6b550b130c9e82221d3c82b7995302"
            },
            {
                "description": "NKO DIGIT ZERO (as \\u escape) does not match",
                "data": "\u07c0",
                "valid": false,
                "id": "df6b550b130c9e82221d3c82b7995302"
            }
        ]
    },
    {
        "description": "ECMA 262 \\D matches everything but ascii digits",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "type": "string",
            "pattern": "^\\D$"
        },
        "tests": [
            {
