    {
        "description": "ECMA 262 \\s matches whitespace",
        "schema": {
            "$schema": "https://json-schema.org/v1",
            "type": "string",
            "pattern": "^\\s$"
        },
        "tests": [
            {
                "description": "ASCII space matches",
                "data": " ",
                "valid": true,
                "id": "a5c5dfe187ebb5c4f06a6ce179618074"
            },
            {
                "description": "Character tabulation matches",
                "data": "\t",
                "valid": true,
                "id": "e810c7dbd99698e9b6398ccb2dd96ca6"
            },
            {
                "description": "Line tabulation matches",
                "data": "\u000b",
                "valid": true,
                "id": "b76b057deea8334d5936e4bb366ecc82"
            },
            {
                "description": "Form feed matches",
                "data": "\u000c",
                "valid": true,
                "id": "16db0fabd6d3b60015f7cd2406bfdff1"
            },
            {
                "description": "latin-1 non-breaking-space matches",
                "data": "\u00a0",
                "valid": true,
                "id": "c723d80e2222901bfee63a9e9488f4e0"
            },
            {
                "description": "zero-width whitespace matches",
                "data": "\ufeff",
                "valid": true,
                "id": "fe29ffa5ca6d05ae76265267191aa854"
            },
            {
                "description": "line feed matches (line terminator)",
                "data": "\u000a",
                "valid": true,
                "id": "f2e41101867234e607f103a318cf6486"
            },
            {
                "description": "paragraph separator matches (line terminator)",
                "data": "\u2029",
                "valid": true,
                "id": "d9a72de38debedd0009a77864082872c"
            },
            {
                "description": "EM SPACE matches (Space_Separator)",
                "data": "\u2003",
                "valid": true,
                "id": "fdfd64be68eef981f9c149990bce5c56"
            },
            {
                "description": "Non-whitespace control does not match",
                "data": "\u0001",
                "valid": false,
                "id": "e600724de2172f85f60ee08a3fdc6a4f"
            },
            {
                "description": "Non-whitespace does not match",
                "data": "\u2013",
                "valid": false,
                "id": "b21c2f62d75dd358515e3e83de376e94"
            }
        ]
    },
