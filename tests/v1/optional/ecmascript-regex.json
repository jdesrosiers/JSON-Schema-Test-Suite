                "data": "0",
                "valid": false,
                "id": "1d1e1cf79f57f2c2622f742b4375eb97"
            },
            {
                "description": "NKO DIGIT ZERO matches (unlike e.g. Python)",
                "data": "߀",
                "valid": true,
                "id": "4780449c3dfebd937087f4ee795d4433"
            },
            {
                "description": "NKO DIGIT ZERO (as \\u escape) matches",
                "data": "\u07c0",
                "valid": true,
                "id": "4780449c3dfebd937087f4ee795d4433"
            }
        ]
    },
    {
