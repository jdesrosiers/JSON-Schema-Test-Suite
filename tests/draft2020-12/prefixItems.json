[
    {
        "description": "a schema given for prefixItems",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "prefixItems": [
                {"type": "integer"},
                {"type": "string"}
            ]
        },
        "tests": [
            {
                "description": "correct types",
                "data": [ 1, "foo" ],
                "valid": true,
                "id": "93cce1d71104c51d84bb8d39465ac615"
            },
            {
                "description": "wrong types",
                "data": [ "foo", 1 ],
                "valid": false,
                "id": "d1b1c591cf4ef2a9c89143ea86708926"
            },
            {
                "description": "incomplete array of items",
                "data": [ 1 ],
                "valid": true,
                "id": "8bcb2ebef64881cb713418eeec89f385"
            },
            {
                "description": "array with additional items",
                "data": [ 1, "foo", true ],
                "valid": true,
                "id": "3b9a92f94cd177745551e9c39cd6f5b3"
            },
            {
                "description": "empty array",
                "data": [ ],
                "valid": true,
                "id": "13ecf5937e3977e9407c82a7c4b895ad"
            },
            {
                "description": "JavaScript pseudo-array is valid",
                "data": {
                    "0": "invalid",
                    "1": "valid",
                    "length": 2
                },
                "valid": true,
                "id": "de5019f2edc920a5312ac39a8035df99"
            }
        ]
    },
    {
        "description": "prefixItems with boolean schemas",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "prefixItems": [true, false]
        },
        "tests": [
            {
                "description": "array with one item is valid",
                "data": [ 1 ],
                "valid": true,
                "id": "ec131c1850bf07bc45f018be4cbde216"
            },
            {
                "description": "array with two items is invalid",
                "data": [ 1, "foo" ],
                "valid": false,
                "id": "fa97c676567a1b7634dd1e8e06a0b034"
            },
            {
                "description": "empty array is valid",
                "data": [],
                "valid": true,
                "id": "2b40b6ed378fdcc40460af99d92800c0"
            }
        ]
    },
    {
        "description": "additional items are allowed by default",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "prefixItems": [{"type": "integer"}]
        },
        "tests": [
            {
                "description": "only the first item is validated",
                "data": [1, "foo", false],
                "valid": true,
                "id": "abc88ef9d87c8e7d33c33fb9e966f168"
            }
        ]
    },
    {
        "description": "prefixItems with null instance elements",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "prefixItems": [
                {
                    "type": "null"
                }
            ]
        },
        "tests": [
            {
                "description": "allows null elements",
                "data": [ null ],
                "valid": true,
                "id": "37dbf797d459d63988224c55fe3fa790"
            }
        ]
    }
]
