                "valid": false,
                "id": "3f16ef9f99110e4d22a429c000589e96"
            }
        ]
    },
    {
        "description": "unevaluatedItems depends on adjacent contains",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "prefixItems": [true],
            "contains": {"type": "string"},
