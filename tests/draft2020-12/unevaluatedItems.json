            }
        ]
    },
    {
        "description": "unevaluatedItems and contains interact to control item dependency relationship",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "if": {
                "contains": {"const": "a"}
            },
            "then": {
                "if": {
                    "contains": {"const": "b"}
                },
                "then": {
                    "if": {
                        "contains": {"const": "c"}
                    }
                }
            },
            "unevaluatedItems": false
        },
        "tests": [
            {
                "description": "empty array is valid",
                "data": [],
                "valid": true,
                "id": "ef2989624a0a584a81d5e45efd1ea64e"
            },
            {
                "description": "only a's are valid",
                "data": [ "a", "a" ],
                "valid": true,
                "id": "bf667cecf68f09216acadb513334854d"
            },
            {
                "description": "a's and b's are valid",
                "data": [ "a", "b", "a", "b", "a" ],
                "valid": true,
                "id": "862d1e64909af66cd87aca658106c4a3"
            },
            {
                "description": "a's, b's and c's are valid",
                "data": [ "c", "a", "c", "c", "b", "a" ],
                "valid": true,
                "id": "e711b026edc95666802a1cafcc570768"
            },
            {
                "description": "only b's are invalid",
                "data": [ "b", "b" ],
                "valid": false,
                "id": "024624cb432864a7ccb115ab020c1f63"
            },
            {
                "description": "only c's are invalid",
                "data": [ "c", "c" ],
                "valid": false,
                "id": "a5ff05c760f4b75203365593f6b23719"
            },
            {
                "description": "only b's and c's are invalid",
                "data": [ "c", "b", "c", "b", "c" ],
                "valid": false,
                "id": "f3fee59ad3fdd9c6263e6e1d5c4050e6"
            },
            {
                "description": "only a's and c's are invalid",
                "data": [ "c", "a", "c", "a", "c" ],
                "valid": false,
                "id": "ac0a548ab48c7f59d4abdf1410393d5a"
            }
        ]
    },
