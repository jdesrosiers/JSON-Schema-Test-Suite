            }
        ]
    },
    {
        "description": "escaped pointer ref",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$defs": {
                "tilde~field": {"type": "integer"},
                "slash/field": {"type": "integer"},
                "percent%field": {"type": "integer"}
            },
            "properties": {
                "tilde": {"$ref": "#/$defs/tilde~0field"},
                "slash": {"$ref": "#/$defs/slash~1field"},
                "percent": {"$ref": "#/$defs/percent%25field"}
            }
        },
        "tests": [
            {
                "description": "slash invalid",
                "data": {"slash": "aoeu"},
                "valid": false,
                "id": "08e550ff94bf0b05c141b705c734e98e"
            },
            {
                "description": "tilde invalid",
                "data": {"tilde": "aoeu"},
                "valid": false,
                "id": "4c10ac5b5e62b70c1e6a0d251a50f4c7"
            },
            {
                "description": "percent invalid",
                "data": {"percent": "aoeu"},
                "valid": false,
                "id": "15f26597a8829c7b2e3b0a157f0f360e"
            },
            {
                "description": "slash valid",
                "data": {"slash": 123},
                "valid": true,
                "id": "8891cae3520a0635b206db21138782e2"
            },
            {
                "description": "tilde valid",
                "data": {"tilde": 123},
                "valid": true,
                "id": "51ba03ae8b0f43b7327fdc7ab4a39200"
            },
            {
                "description": "percent valid",
                "data": {"percent": 123},
                "valid": true,
                "id": "17873c7d9e603156a70a0d2f1b01a733"
            }
        ]
    },
    {
        "description": "nested refs",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$defs": {
                "a": {"type": "integer"},
                "b": {"$ref": "#/$defs/a"},
