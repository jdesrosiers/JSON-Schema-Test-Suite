[
    {
        "description": "root pointer ref",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "properties": {
                "foo": {"$ref": "#"}
            },
            "additionalProperties": false
        },
        "tests": [
            {
                "description": "match",
                "data": {"foo": false},
                "valid": true,
                "id": "66ab761828ec6cae6b86641258cdfab4"
            },
            {
                "description": "recursive match",
                "data": {"foo": {"foo": false}},
                "valid": true,
                "id": "121f800308fefab7a92b2af552dd5cc0"
            },
            {
                "description": "mismatch",
                "data": {"bar": false},
                "valid": false,
                "id": "b3a8c0f36ef4cb6d2fd0a53cdc7e7a6d"
            },
            {
                "description": "recursive mismatch",
                "data": {"foo": {"bar": false}},
                "valid": false,
                "id": "8bbb600b327d0180bb54ce064511fccb"
            }
        ]
    },
    {
        "description": "relative pointer ref to object",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
