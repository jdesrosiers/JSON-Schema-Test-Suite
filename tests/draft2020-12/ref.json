        },
        "tests": [
            {
                "description": "match",
                "data": {"bar": 3},
                "valid": true,
                "id": "1cb1627ac85bef7dfad9d6e8388205f8"
            },
            {
                "description": "mismatch",
                "data": {"bar": true},
                "valid": false,
                "id": "d60e9be3bd4e00ef14ae5cef5e97d5ed"
            }
        ]
    },
    {
        "description": "relative pointer ref to array",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
