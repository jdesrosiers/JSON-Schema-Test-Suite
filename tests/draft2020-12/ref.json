                "valid": false,
                "id": "852ac54fcf1bcb007cbaf79e154cdb3a"
            }
        ]
    },
    {
        "description": "ref applies alongside sibling keywords",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$defs": {
                "reffed": {
                    "type": "array"
                }
            },
            "properties": {
                "foo": {
                    "$ref": "#/$defs/reffed",
                    "maxItems": 2
                }
            }
        },
        "tests": [
            {
                "description": "ref valid, maxItems valid",
                "data": { "foo": [] },
                "valid": true,
                "id": "07b17eceaa698a879324f61648f8e457"
            },
            {
                "description": "ref valid, maxItems invalid",
                "data": { "foo": [1, 2, 3] },
                "valid": false,
                "id": "e80403bbae7a9fdba174df7a9093d1cf"
            },
            {
                "description": "ref invalid",
                "data": { "foo": "string" },
                "valid": false,
                "id": "6f4c9ec0ddc645b0a8029e8211a5bd87"
            }
        ]
    },
