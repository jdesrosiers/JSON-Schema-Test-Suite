            }
        ]
    },
    {
        "description": "base URI change - change folder",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "http://localhost:1234/draft2020-12/scope_change_defs1.json",
            "type" : "object",
            "properties": {"list": {"$ref": "baseUriChangeFolder/"}},
            "$defs": {
                "baz": {
                    "$id": "baseUriChangeFolder/",
                    "type": "array",
                    "items": {"$ref": "folderInteger.json"}
                }
            }
        },
        "tests": [
            {
                "description": "number is valid",
                "data": {"list": [1]},
                "valid": true,
                "id": "9442dd4649855acc5be9e791db6776df"
            },
            {
                "description": "string is invalid",
                "data": {"list": ["a"]},
                "valid": false,
                "id": "50d65ca06cc88947cefdcfa50e83ffed"
            }
        ]
    },
    {
        "description": "base URI change - change folder in subschema",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "http://localhost:1234/draft2020-12/scope_change_defs2.json",
            "type" : "object",
            "properties": {"list": {"$ref": "baseUriChangeFolderInSubschema/#/$defs/bar"}},
            "$defs": {
                "baz": {
                    "$id": "baseUriChangeFolderInSubschema/",
                    "$defs": {
                        "bar": {
                            "type": "array",
                            "items": {"$ref": "folderInteger.json"}
                        }
                    }
                }
            }
        },
        "tests": [
            {
                "description": "number is valid",
                "data": {"list": [1]},
                "valid": true,
                "id": "62f23807cc1f4900f58817801db0eef3"
            },
            {
                "description": "string is invalid",
                "data": {"list": ["a"]},
                "valid": false,
                "id": "b6e5f67af777f4981957e17f83b0d935"
            }
        ]
    },
    {
        "description": "root ref in remote ref",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "http://localhost:1234/draft2020-12/object",
            "type": "object",
            "properties": {
                "name": {"$ref": "name-defs.json#/$defs/orNull"}
            }
        },
        "tests": [
