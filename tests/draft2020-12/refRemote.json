                "data": {
                    "name": "foo"
                },
                "valid": true,
                "id": "29222415fc321244933c8c20dfd6b7c9"
            },
            {
                "description": "null is valid",
                "data": {
                    "name": null
                },
                "valid": true,
                "id": "8e930be9492ebb3b9609aa0cd4b9b325"
            },
            {
                "description": "object is invalid",
                "data": {
                    "name": {
                        "name": null
                    }
                },
                "valid": false,
                "id": "cd41a0bcba224e1b31c523a1fb646fd8"
            }
        ]
    },
