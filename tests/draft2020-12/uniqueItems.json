[
    {
        "description": "uniqueItems validation",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "uniqueItems": true
        },
        "tests": [
            {
                "description": "unique array of integers is valid",
                "data": [1, 2],
                "valid": true,
                "id": "fb68d78530335693faa42e86c8c244bb"
            },
            {
                "description": "non-unique array of integers is invalid",
                "data": [1, 1],
                "valid": false,
                "id": "581e4ff32b39e4b73ecc8bd70ef1beab"
            },
            {
                "description": "non-unique array of more than two integers is invalid",
                "data": [1, 2, 1],
                "valid": false,
                "id": "45f0ad4c7261e8cd9a297176a4e1af41"
            },
            {
                "description": "numbers are unique if mathematically unequal",
                "data": [1.0, 1.00, 1],
                "valid": false,
                "id": "6b0ff9908bc53c186e09b58b40806507"
            },
            {
                "description": "false is not equal to zero",
                "data": [0, false],
                "valid": true,
                "id": "9e374ca89c6b4a6fc972e85ae0c0f4f9"
            },
            {
                "description": "true is not equal to one",
                "data": [1, true],
                "valid": true,
                "id": "e81ac447c37c0bf27b374dd80ee21bf7"
            },
            {
                "description": "unique array of strings is valid",
                "data": ["foo", "bar", "baz"],
                "valid": true,
                "id": "f3ff3434819597a8d52a3f9688007216"
            },
            {
                "description": "non-unique array of strings is invalid",
                "data": ["foo", "bar", "foo"],
                "valid": false,
                "id": "4accf1b2f3cae907cc8d625268c474a2"
            },
            {
                "description": "unique array of objects is valid",
                "data": [{"foo": "bar"}, {"foo": "baz"}],
                "valid": true,
                "id": "ec83eabf59e1b36ac3231092d91320c9"
            },
            {
                "description": "non-unique array of objects is invalid",
                "data": [{"foo": "bar"}, {"foo": "bar"}],
                "valid": false,
                "id": "6887d5dfbe0eb476b7b4b673b43e4c43"
            },
            {
                "description": "property order of array of objects is ignored",
                "data": [{"foo": "bar", "bar": "foo"}, {"bar": "foo", "foo": "bar"}],
                "valid": false,
                "id": "0e00b297858f09a8dff2860e7cd4a488"
            },
            {
                "description": "unique array of nested objects is valid",
                "data": [
                    {"foo": {"bar" : {"baz" : true}}},
                    {"foo": {"bar" : {"baz" : false}}}
                ],
                "valid": true,
                "id": "3aa4f6759667fe9063c384bd36075f15"
            },
            {
                "description": "non-unique array of nested objects is invalid",
                "data": [
                    {"foo": {"bar" : {"baz" : true}}},
                    {"foo": {"bar" : {"baz" : true}}}
                ],
                "valid": false,
                "id": "3a219c72bb3debe40fc05ef87b578032"
            },
            {
                "description": "unique array of arrays is valid",
                "data": [["foo"], ["bar"]],
                "valid": true,
                "id": "e1fb943ff5a932d6405d4cdbe133292c"
            },
            {
                "description": "non-unique array of arrays is invalid",
                "data": [["foo"], ["foo"]],
                "valid": false,
                "id": "d92069ae77dcb1781310479c25b4754d"
            },
            {
                "description": "non-unique array of more than two arrays is invalid",
                "data": [["foo"], ["bar"], ["foo"]],
                "valid": false,
                "id": "1c16b6ff34a3811a7d70057374b7c9b2"
            },
            {
                "description": "1 and true are unique",
                "data": [1, true],
                "valid": true,
                "id": "e81ac447c37c0bf27b374dd80ee21bf7"
            },
            {
                "description": "0 and false are unique",
                "data": [0, false],
                "valid": true,
                "id": "9e374ca89c6b4a6fc972e85ae0c0f4f9"
            },
            {
                "description": "[1] and [true] are unique",
                "data": [[1], [true]],
                "valid": true,
                "id": "c37e1756d21f211686e35fcebb63f395"
            },
            {
                "description": "[0] and [false] are unique",
                "data": [[0], [false]],
                "valid": true,
                "id": "bcceffffa4169bcdb430e03437801a87"
            },
            {
                "description": "nested [1] and [true] are unique",
                "data": [[[1], "foo"], [[true], "foo"]],
                "valid": true,
                "id": "52a4a61de7ec47c2506d67a09eca0d18"
            },
            {
                "description": "nested [0] and [false] are unique",
                "data": [[[0], "foo"], [[false], "foo"]],
                "valid": true,
                "id": "287ff25f2e01211122ad6ee55f4ef69b"
            },
            {
                "description": "unique heterogeneous types are valid",
                "data": [{}, [1], true, null, 1, "{}"],
                "valid": true,
                "id": "9acb4ca5896979665dec2868c42e5774"
            },
            {
                "description": "non-unique heterogeneous types are invalid",
                "data": [{}, [1], true, null, {}, 1],
                "valid": false,
                "id": "752e7db52ca6e2faee89aaf37832d7cd"
            },
            {
                "description": "different objects are unique",
                "data": [{"a": 1, "b": 2}, {"a": 2, "b": 1}],
                "valid": true,
                "id": "fa592234ea5698ab7ccc246d30b23a5d"
            },
            {
                "description": "objects are non-unique despite key order",
                "data": [{"a": 1, "b": 2}, {"b": 2, "a": 1}],
                "valid": false,
                "id": "8a6374259d6108b8fbbbf8b46d253263"
            },
            {
                "description": "{\"a\": false} and {\"a\": 0} are unique",
                "data": [{"a": false}, {"a": 0}],
                "valid": true,
                "id": "9236ffc646d65ac72031fe7a5e4254d5"
            },
            {
                "description": "{\"a\": true} and {\"a\": 1} are unique",
                "data": [{"a": true}, {"a": 1}],
                "valid": true,
                "id": "fce37fb81f3363d08b4844e0f8b99150"
            }
        ]
    },
    {
        "description": "uniqueItems with an array of items",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "prefixItems": [{"type": "boolean"}, {"type": "boolean"}],
            "uniqueItems": true
        },
        "tests": [
            {
                "description": "[false, true] from items array is valid",
                "data": [false, true],
                "valid": true,
                "id": "63081877dfeaf5abe8c2e3aa52eb5600"
            },
            {
                "description": "[true, false] from items array is valid",
                "data": [true, false],
                "valid": true,
                "id": "e6bc585a0dc3e98f00ad57211b62a82d"
            },
            {
                "description": "[false, false] from items array is not valid",
                "data": [false, false],
                "valid": false,
                "id": "bda0220fdb423f90632fde1a56289696"
            },
            {
                "description": "[true, true] from items array is not valid",
                "data": [true, true],
                "valid": false,
                "id": "d8f30a2349b8525d46ebd2aa76a396c5"
            },
            {
                "description": "unique array extended from [false, true] is valid",
                "data": [false, true, "foo", "bar"],
                "valid": true,
                "id": "2f5ee1910fa5619f1defbdfcb8b28563"
            },
            {
                "description": "unique array extended from [true, false] is valid",
                "data": [true, false, "foo", "bar"],
                "valid": true,
                "id": "4b71f41f25ffda299fde5a72c27e1776"
            },
            {
                "description": "non-unique array extended from [false, true] is not valid",
                "data": [false, true, "foo", "foo"],
                "valid": false,
                "id": "3738966edc128798d122fd452c9c7abe"
            },
            {
                "description": "non-unique array extended from [true, false] is not valid",
                "data": [true, false, "foo", "foo"],
                "valid": false,
                "id": "fdb49cf6a27a318e2fb3aaa661bef7f9"
            }
        ]
    },
    {
        "description": "uniqueItems with an array of items and additionalItems=false",
        "schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "prefixItems": [{"type": "boolean"}, {"type": "boolean"}],
            "uniqueItems": true,
            "items": false
        },
        "tests": [
            {
                "description": "[false, true] from items array is valid",
                "data": [false, true],
                "valid": true,
                "id": "e1544fccf6f0b5cda3fd09cd83743729"
            },
            {
                "description": "[true, false] from items array is valid",
                "data": [true, false],
                "valid": true,
                "id": "f1bafbc1280ff35da05b9ada4c8ba590"
            },
            {
                "description": "[false, false] from items array is not valid",
                "data": [false, false],
                "valid": false,
                "id": "a6a1517c616a73c53e9c685c60a72cc9"
            },
            {
                "description": "[true, true] from items array is not valid",
                "data": [true, true],
                "valid": false,
                "id": "bf8883961fc6ec36bb01710898132e18"
            },
            {
                "description": "extra items are invalid even if unique",
                "data": [false, true, null],
                "valid": false,
                "id": "4d5658ba3ad8d77e80a543429855e54e"
            }
        ]
    },
