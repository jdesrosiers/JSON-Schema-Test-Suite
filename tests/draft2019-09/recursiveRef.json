[
    {
        "description": "$recursiveRef without $recursiveAnchor works like $ref",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "properties": {
                "foo": { "$recursiveRef": "#" }
            },
            "additionalProperties": false
        },
        "tests": [
            {
                "description": "match",
                "data": {"foo": false},
                "valid": true,
                "id": "ace38449bb86dbf81af38b5e78273583"
            },
            {
                "description": "recursive match",
                "data": { "foo": { "foo": false } },
                "valid": true,
                "id": "e53b7bdf3bd047b1aefbb65a58055d49"
            },
            {
                "description": "mismatch",
                "data": { "bar": false },
                "valid": false,
                "id": "c76b3355f7b68952d6003103220ae091"
            },
            {
                "description": "recursive mismatch",
                "data": { "foo": { "bar": false } },
                "valid": false,
                "id": "21c5058aa9eb8142e3e585d1d331414d"
            }
        ]
    },
    {
        "description": "$recursiveRef without using nesting",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "$id": "http://localhost:4242/draft2019-09/recursiveRef2/schema.json",
            "$defs": {
                "myobject": {
                    "$id": "myobject.json",
                    "$recursiveAnchor": true,
                    "anyOf": [
                        { "type": "string" },
                        {
                            "type": "object",
                            "additionalProperties": { "$recursiveRef": "#" }
                        }
                    ]
                }
            },
            "anyOf": [
                { "type": "integer" },
                { "$ref": "#/$defs/myobject" }
            ]
        },
        "tests": [
            {
                "description": "integer matches at the outer level",
                "data": 1,
                "valid": true,
                "id": "718512a980e182c4836d460707db19fa"
            },
            {
                "description": "single level match",
                "data": { "foo": "hi" },
                "valid": true,
                "id": "bfda17c6068280c8457d2968bb055f4e"
            },
            {
                "description": "integer does not match as a property value",
                "data": { "foo": 1 },
                "valid": false,
                "id": "6bedf05b8b3610a6cff9beb393dbaff0"
            },
            {
                "description": "two levels, properties match with inner definition",
                "data": { "foo": { "bar": "hi" } },
                "valid": true,
                "id": "7d7b855e31a4f94bec515d7be7c0a155"
            },
            {
                "description": "two levels, no match",
                "data": { "foo": { "bar": 1 } },
                "valid": false,
                "id": "a0496689fa6ec2d3fca1b6bfc40e8331"
            }
        ]
    },
