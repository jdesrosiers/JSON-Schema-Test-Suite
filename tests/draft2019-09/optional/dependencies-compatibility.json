[
    {
        "description": "single dependency",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "dependencies": {"bar": ["foo"]}
        },
        "tests": [
            {
                "description": "neither",
                "data": {},
                "valid": true,
                "id": "814bd92b4fdea565b80c44489d36dd1a"
            },
            {
                "description": "nondependant",
                "data": {"foo": 1},
                "valid": true,
                "id": "c25dfa97c4428dc0db737d33c7875031"
            },
            {
                "description": "with dependency",
                "data": {"foo": 1, "bar": 2},
                "valid": true,
                "id": "659e7562bec611f700676f2b2a9e0e80"
            },
            {
                "description": "missing dependency",
                "data": {"bar": 2},
                "valid": false,
                "id": "e947ea76e8e6867adb1dd397b72073dd"
            },
            {
                "description": "ignores arrays",
                "data": ["bar"],
                "valid": true,
                "id": "ae70e41385adef7842d31f193b93015b"
            },
            {
                "description": "ignores strings",
                "data": "foobar",
                "valid": true,
                "id": "5287cdbc75cc6baa2b71d2646dabc52b"
            },
            {
                "description": "ignores other non-objects",
                "data": 12,
                "valid": true,
                "id": "f0a68a4997e3405d98088d386e880e01"
            }
        ]
    },
    {
        "description": "empty dependents",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "dependencies": {"bar": []}
        },
        "tests": [
            {
                "description": "empty object",
                "data": {},
                "valid": true,
                "id": "b2427bf6eeccfe5dfd8a10ca88a17045"
            },
            {
                "description": "object with one property",
                "data": {"bar": 2},
                "valid": true,
                "id": "7c950d801a5a4ca9ca33d7f738458754"
            },
            {
                "description": "non-object is valid",
                "data": 1,
                "valid": true,
                "id": "3f24372f407fc7b7179c41b45a0f0970"
            }
        ]
    },
    {
        "description": "multiple dependents required",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "dependencies": {"quux": ["foo", "bar"]}
        },
        "tests": [
            {
                "description": "neither",
                "data": {},
                "valid": true,
                "id": "9adb93bc2c206c5accb6266af950c4f8"
            },
            {
                "description": "nondependants",
                "data": {"foo": 1, "bar": 2},
                "valid": true,
                "id": "53f8913d400c8c2b72aded33fe1cc65b"
            },
            {
                "description": "with dependencies",
                "data": {"foo": 1, "bar": 2, "quux": 3},
                "valid": true,
                "id": "d9280a8783933c1d6f5d3ae35de860be"
            },
            {
                "description": "missing dependency",
                "data": {"foo": 1, "quux": 2},
                "valid": false,
                "id": "be07791c0331a02fe6e7e9f0ea92736f"
            },
            {
                "description": "missing other dependency",
                "data": {"bar": 1, "quux": 2},
                "valid": false,
                "id": "752e21f8efc9fb969243b4a1a6dfafde"
            },
            {
                "description": "missing both dependencies",
                "data": {"quux": 1},
                "valid": false,
                "id": "dac73b6938059883766e6c1c4c915f2e"
            }
        ]
    },
    {
        "description": "dependencies with escaped characters",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "dependencies": {
                "foo\nbar": ["foo\rbar"],
                "foo\"bar": ["foo'bar"]
            }
        },
        "tests": [
            {
                "description": "CRLF",
                "data": {
                    "foo\nbar": 1,
                    "foo\rbar": 2
                },
                "valid": true,
                "id": "08bd0cf9c719e44440d9d6cb39dfce7c"
            },
            {
                "description": "quoted quotes",
                "data": {
                    "foo'bar": 1,
                    "foo\"bar": 2
                },
                "valid": true,
                "id": "9d07c98db0ea48b827e8e314a8f6a90a"
            },
            {
                "description": "CRLF missing dependent",
                "data": {
                    "foo\nbar": 1,
                    "foo": 2
                },
                "valid": false,
                "id": "8e3b526b0c8553ee8af4605f91c9bf70"
            },
            {
                "description": "quoted quotes missing dependent",
                "data": {
                    "foo\"bar": 2
                },
                "valid": false,
                "id": "64f1ffdf64aa85e9b0b54823547ebf30"
            }
        ]
    },
    {
        "description": "single schema dependency",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "dependencies": {
                "bar": {
                    "properties": {
                        "foo": {"type": "integer"},
                        "bar": {"type": "integer"}
                    }
                }
            }
        },
        "tests": [
            {
                "description": "valid",
                "data": {"foo": 1, "bar": 2},
                "valid": true,
                "id": "b54cf54c30c8acb9e85f139189a8da91"
            },
            {
                "description": "no dependency",
                "data": {"foo": "quux"},
                "valid": true,
                "id": "377e1053cc53a300da7734229413e1c8"
            },
            {
                "description": "wrong type",
                "data": {"foo": "quux", "bar": 2},
                "valid": false,
                "id": "b56079c67ac42129abf59b9e8c3db64b"
            },
            {
                "description": "wrong type other",
                "data": {"foo": 2, "bar": "quux"},
                "valid": false,
                "id": "b042d593b288a9a3eff48c76809aef01"
            },
            {
                "description": "wrong type both",
                "data": {"foo": "quux", "bar": "quux"},
                "valid": false,
                "id": "7e67ffb21a1a8b073e0463b1036ea95d"
            },
            {
                "description": "ignores arrays",
                "data": ["bar"],
                "valid": true,
                "id": "530c9171a1c7ade9048f1a429af67f36"
            },
            {
                "description": "ignores strings",
                "data": "foobar",
                "valid": true,
                "id": "595d5f1f3b595200cb541a47214dbd80"
            },
            {
                "description": "ignores other non-objects",
                "data": 12,
                "valid": true,
                "id": "b9d366ab8128f6baa7134ca594c3df00"
            }
        ]
    },
    {
        "description": "boolean subschemas",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "dependencies": {
                "foo": true,
                "bar": false
            }
        },
        "tests": [
            {
                "description": "object with property having schema true is valid",
                "data": {"foo": 1},
                "valid": true,
                "id": "8e19bd574e583e0d941ac9dc072fe288"
            },
            {
                "description": "object with property having schema false is invalid",
                "data": {"bar": 2},
                "valid": false,
                "id": "5ab3a1c03baf1eea8af0f3f8e08f1262"
            },
            {
                "description": "object with both properties is invalid",
                "data": {"foo": 1, "bar": 2},
                "valid": false,
                "id": "828a5223e33989ce0f88b5851e1899f9"
            },
            {
                "description": "empty object is valid",
                "data": {},
                "valid": true,
                "id": "690e6e75400bb958f90e4696a148ef92"
            }
        ]
    },
    {
        "description": "schema dependencies with escaped characters",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "dependencies": {
                "foo\tbar": {"minProperties": 4},
                "foo'bar": {"required": ["foo\"bar"]}
            }
        },
        "tests": [
            {
                "description": "quoted tab",
                "data": {
                    "foo\tbar": 1,
                    "a": 2,
                    "b": 3,
                    "c": 4
                },
                "valid": true,
                "id": "077d1d2d6c55ef8f801d749b491920db"
            },
            {
                "description": "quoted quote",
                "data": {
                    "foo'bar": {"foo\"bar": 1}
                },
                "valid": false,
                "id": "cfc97624efd599f431b1c36fe70f4871"
            },
            {
                "description": "quoted tab invalid under dependent schema",
                "data": {
                    "foo\tbar": 1,
                    "a": 2
                },
                "valid": false,
                "id": "3121bb645ccc42d8131981e73eec23d0"
            },
            {
                "description": "quoted quote invalid under dependent schema",
                "data": {"foo'bar": 1},
                "valid": false,
                "id": "2cb4d4fee02416b2d15d61b691f57380"
            }
        ]
    }
]
