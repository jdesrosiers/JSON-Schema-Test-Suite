    {
        "description": "same $anchor with different base uri",
        "schema": {
            "$schema": "https://json-schema.org/draft/2019-09/schema",
            "$id": "http://localhost:1234/draft2019-09/foobar",
            "$defs": {
                "A": {
                    "$id": "child1",
                    "allOf": [
                        {
                            "$id": "child2",
                            "$anchor": "my_anchor",
                            "type": "number"
                        },
                        {
                            "$anchor": "my_anchor",
                            "type": "string"
                        }
                    ]
                }
            },
            "$ref": "child1#my_anchor"
        },
        "tests": [
            {
                "description": "$ref resolves to /$defs/A/allOf/1",
                "data": "a",
                "valid": true,
                "id": "ed71d6cf6a8508de534fd3a3428a2374"
            },
            {
                "description": "$ref does not resolve to /$defs/A/allOf/0",
                "data": 1,
                "valid": false,
                "id": "c915f59fc28b238f92ba4c1baeebd8fd"
            }
        ]
    }
]
