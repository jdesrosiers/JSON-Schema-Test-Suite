[
    {
        "description": "const validation",
        "schema": {"const": 2},
        "tests": [
            {
                "description": "same value is valid",
                "data": 2,
                "valid": true,
                "id": "56f05cd0be52f5df928cc150319f420f"
            },
            {
                "description": "another value is invalid",
                "data": 5,
                "valid": false,
                "id": "1a057c494bad279a92cbe29963940248"
            },
            {
                "description": "another type is invalid",
                "data": "a",
                "valid": false,
                "id": "f7a26e1b6979283812b52c46b9271ff5"
            }
        ]
    },
    {
        "description": "const with object",
        "schema": {"const": {"foo": "bar", "baz": "bax"}},
        "tests": [
            {
                "description": "same object is valid",
                "data": {"foo": "bar", "baz": "bax"},
                "valid": true,
                "id": "140a9df8b6c56e24a89a000ba5f49368"
            },
            {
                "description": "same object with different property order is valid",
                "data": {"baz": "bax", "foo": "bar"},
                "valid": true,
                "id": "140a9df8b6c56e24a89a000ba5f49368"
            },
            {
                "description": "another object is invalid",
                "data": {"foo": "bar"},
                "valid": false,
                "id": "2f052298d72845af7722a4fb9a2534c8"
            },
            {
                "description": "another type is invalid",
                "data": [1, 2],
                "valid": false,
                "id": "b131db102fbd7f128de7b9de689ae919"
            }
        ]
    },
    {
        "description": "const with array",
        "schema": {"const": [{ "foo": "bar" }]},
        "tests": [
            {
                "description": "same array is valid",
                "data": [{"foo": "bar"}],
                "valid": true,
                "id": "68096e413b580eb410e2d882baf66fcb"
            },
            {
                "description": "another array item is invalid",
                "data": [2],
                "valid": false,
                "id": "07a333ddabac06a9c4c38d06c2b5f62d"
            },
            {
                "description": "array with additional items is invalid",
                "data": [1, 2, 3],
                "valid": false,
                "id": "7a4d787c4dca59602bb84d71a97dd2cd"
            }
        ]
    },
