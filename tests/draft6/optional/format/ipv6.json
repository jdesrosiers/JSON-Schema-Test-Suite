                "valid": true,
                "id": "ca64db212e369abd963cd1277b25065a"
            },
            {
                "description": "triple colons is invalid",
                "data": "1:2:3:4:5:::8",
                "valid": false,
                "id": "30d8e46bd8753f2f8525cb1ac96c334b"
            },
            {
                "description": "8 octets",
                "data": "1:2:3:4:5:6:7:8",
                "valid": true,
                "id": "e53cb106d320b61bd0cb1a777e692d61"
            },
            {
                "description": "insufficient octets without double colons",
                "data": "1:2:3:4:5:6:7",
                "valid": false,
                "id": "eb2f2ce4404913809268e1067329820a"
            },
            {
                "description": "no colons is invalid",
                "data": "1",
                "valid": false,
                "id": "eaeb8de1b435863a2d650b4b5541d8d2"
            },
            {
                "description": "ipv4 is not ipv6",
