            }
        ]
    },
    {
        "description": "anyOf with boolean schemas, all true",
        "schema": {"anyOf": [true, true]},
        "tests": [
            {
                "description": "any value is valid",
                "data": "foo",
                "valid": true,
                "id": "e5323eee13c8914b0ab5a9d404f9a074"
            }
        ]
    },
    {
        "description": "anyOf with boolean schemas, some true",
