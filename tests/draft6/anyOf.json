        "tests": [
            {
                "description": "any value is valid",
                "data": "foo",
                "valid": true,
                "id": "6c1ed91bfba6651d429cc7ee1e963a4e"
            }
        ]
    },
    {
        "description": "anyOf with boolean schemas, all false",
        "schema": {"anyOf": [false, false]},
        "tests": [
            {
                "description": "any value is invalid",
                "data": "foo",
                "valid": false,
                "id": "f19524b506011eb920961dc2bec75e5d"
            }
        ]
    },
    {
        "description": "anyOf complex types",
        "schema": {
            "anyOf": [
                {
                    "properties": {
                        "bar": {"type": "integer"}
                    },
                    "required": ["bar"]
                },
                {
                    "properties": {
                        "foo": {"type": "string"}
                    },
                    "required": ["foo"]
                }
            ]
        },
        "tests": [
            {
                "description": "first anyOf valid (complex)",
                "data": {"bar": 2},
                "valid": true,
                "id": "58df711332c9fa5885605dd48788a16d"
            },
            {
                "description": "second anyOf valid (complex)",
                "data": {"foo": "baz"},
                "valid": true,
                "id": "4f40ae70196c999ac315d885f8f7c5f8"
            },
            {
                "description": "both anyOf valid (complex)",
                "data": {"foo": "baz", "bar": 2},
                "valid": true,
                "id": "2f13ae957b7ae00a3b773fae1cc8d9d0"
            },
            {
                "description": "neither anyOf valid (complex)",
                "data": {"foo": 2, "bar": "quux"},
                "valid": false,
                "id": "8bdc89af8e10dcc2fb9ff297962ade02"
            }
        ]
    },
    {
        "description": "anyOf with one empty schema",
        "schema": {
            "anyOf": [
                { "type": "number" },
                {}
            ]
        },
        "tests": [
            {
                "description": "string is valid",
                "data": "foo",
                "valid": true,
                "id": "5772907ad1a241e1d66d5b31a1b4450a"
            },
            {
                "description": "number is valid",
                "data": 123,
                "valid": true,
                "id": "8c60f23bb06f50dede3975a3e79bc228"
            }
        ]
    },
    {
        "description": "nested anyOf, to check validation semantics",
        "schema": {
            "anyOf": [
                {
                    "anyOf": [
                        {
                            "type": "null"
                        }
                    ]
                }
            ]
        },
        "tests": [
            {
                "description": "null is valid",
                "data": null,
                "valid": true,
                "id": "a9fc75a6d76f74913b9542f85ed3796f"
            },
            {
                "description": "anything non-null is invalid",
                "data": 123,
                "valid": false,
                "id": "d249aeb29652e1b5b8169e686427c9fd"
            }
        ]
    }
]
